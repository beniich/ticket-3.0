# Environment variables — School Settings Backend

# Serveur
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Base de données PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/school_settings_db"

# JWT
JWT_SECRET="change_this_to_a_very_long_random_secret_at_least_64_chars"
JWT_EXPIRES_IN="7d"
